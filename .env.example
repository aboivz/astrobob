# AstroBob Configuration
# Copy this file to .env and fill in your values

# AstraDB Configuration (Required)
# Get these from your AstraDB dashboard: https://astra.datastax.com
ASTRA_DB_API_ENDPOINT=https://YOUR_DATABASE_ID-YOUR_REGION.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=AstraCS:YOUR_TOKEN_HERE

# Optional: Collection prefix (default: astrobob)
# ASTROBOB_COLLECTION_PREFIX=astrobob

# Optional: Default project name (default: default)
# ASTROBOB_DEFAULT_PROJECT=myproject

# Optional: Logging level (default: INFO)
# ASTROBOB_LOG_LEVEL=INFO